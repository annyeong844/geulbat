{
  "name": "@geulbat/web-shell",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:artifact-runtime-sources": "node ./scripts/sync-artifact-runtime-sources.mjs",
    "check:artifact-runtime-sources": "node ./scripts/sync-artifact-runtime-sources.mjs --check",
    "smoke:react-bundle": "node --import tsx ./scripts/react-bundle-smoke.mjs",
    "smoke:public-web-conformance": "node --import tsx ./scripts/public-web-conformance-smoke.mjs",
    "smoke:react-bundle:install-browser": "playwright install chromium",
    "dev": "node ../../scripts/run-with-local-dev-auth.mjs vite",
    "build:deps": "tsc -b ../../packages/shared-utils/tsconfig.json ../../packages/protocol/tsconfig.json",
    "build:app": "npm run check:artifact-runtime-sources && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "build": "npm run build:deps && npm run build:app",
    "check:app": "npm run check:artifact-runtime-sources && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "check": "npm run build:deps && npm run check:app",
    "test:files": "npm run check:artifact-runtime-sources && node ../../scripts/run-workspace-node-tests.mjs --workspace web-shell --tsconfig ./tsconfig.test.json",
    "test:app": "npm run test:files -- \"**/*.test.js\"",
    "test": "npm run build:deps && npm run test:app",
    "preview": "vite preview"
  },
  "dependencies": {
    "@geulbat/protocol": "*",
    "@geulbat/shared-utils": "*",
    "@tanstack/react-virtual": "^3.14.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitejs/plugin-react": "^4.4.0",
    "playwright": "^1.59.1",
    "react-test-renderer": "^19.2.4",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "^6.4.3"
  }
}
