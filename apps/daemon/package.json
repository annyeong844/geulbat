{
  "name": "@geulbat/daemon",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [
    "dist/",
    "creator-plugin/",
    "provider-auth.config.json"
  ],
  "imports": {
    "#web/auth/*.js": "./src/adapter/web/auth/*.ts",
    "#web/request/*.js": "./src/adapter/web/request/*.ts",
    "#web/response/*.js": "./src/adapter/web/response/*.ts",
    "#web/origin-policy.js": "./src/adapter/web/origin-policy.ts"
  },
  "scripts": {
    "build:deps": "tsc -b ../../packages/shared-utils/tsconfig.json ../../packages/protocol/tsconfig.json ../../packages/agent-loop/tsconfig.json ../../packages/tool-sdk/tsconfig.json ../../packages/tool-library/tsconfig.json",
    "dev": "node ./scripts/dev-daemon-supervisor.mjs",
    "dev:checked": "node ./scripts/dev-precheck.mjs && node ./scripts/dev-daemon-supervisor.mjs",
    "dev:no-watch": "GEULBAT_DEV_NO_WATCH=1 node ./scripts/dev-daemon-supervisor.mjs",
    "dev:dist": "GEULBAT_DEV_USE_DIST=1 GEULBAT_DEV_NO_WATCH=1 node ./scripts/dev-daemon-supervisor.mjs",
    "discover:oauth-wire": "node --import tsx ./scripts/collect-oauth-structured-output-wire-evidence.mjs",
    "probe:grok-cache": "node --import tsx ./scripts/probe-grok-prompt-cache.mjs",
    "reset:single-home": "node ./scripts/reset-single-home-state.mjs --root ../..",
    "test:single-home-reset": "node --test ./scripts/reset-single-home-state.test.mjs",
    "build:app": "tsc -b tsconfig.app.json && node ./scripts/sync-package-imports.mjs dist",
    "build": "npm run build:deps && npm run build:app",
    "check:app": "tsc --noEmit -p tsconfig.app.json",
    "check": "npm run build:deps && npm run check:app",
    "test:dev-supervisor": "node --test ./scripts/dev-daemon-supervisor.test.mjs",
    "test:scripts": "node --test \"./scripts/*.test.mjs\"",
    "test:files": "node ../../scripts/run-workspace-node-tests.mjs --workspace daemon --tsconfig ./tsconfig.test.json --post-build-script ./scripts/sync-package-imports.mjs",
    "test:e2e:ptc-browser": "npm run test:files -- \"daemon/ptc/runtime/browser/*e2e.test.js\"",
    "test:app": "npm run test:files -- \"**/*.test.js\" && npm run test:scripts",
    "test": "npm run build:deps && npm run test:app",
    "test:cov": "npm run build:deps && npx --yes node@24 ../../scripts/run-workspace-node-tests.mjs --workspace daemon --tsconfig ./tsconfig.test.json --post-build-script ./scripts/sync-package-imports.mjs --coverage-output ./coverage/daemon -- \"**/*.test.js\"",
    "start": "node dist/index.js"
  },
  "c8": {
    "all": true,
    "branches": 82,
    "check-coverage": true,
    "exclude": [
      "**/*.d.ts",
      "src/**/*.test.ts",
      "src/test-support/**",
      "src/adapter/web/ws/run-channel-test-support.ts"
    ],
    "exclude-after-remap": true,
    "functions": 90,
    "lines": 91,
    "reporter": [
      "text-summary",
      "lcov"
    ],
    "src": [
      "src"
    ],
    "statements": 91
  },
  "dependencies": {
    "@geulbat/agent-loop": "*",
    "@geulbat/protocol": "*",
    "@geulbat/shared-utils": "*",
    "@geulbat/tool-sdk": "*",
    "@geulbat/tool-library": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.17.1",
    "cross-spawn": "^7.0.6",
    "esbuild": "^0.28.1",
    "express": "^5.0.1",
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "chokidar": "^5.0.0",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
