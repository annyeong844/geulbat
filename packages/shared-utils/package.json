{
  "name": "@geulbat/shared-utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./process-command": {
      "types": "./dist/process-command.d.ts",
      "import": "./dist/process-command.js"
    },
    "./sha256": {
      "types": "./dist/sha256.d.ts",
      "import": "./dist/sha256.js"
    },
    "./stable-json": {
      "types": "./dist/stable-json.d.ts",
      "import": "./dist/stable-json.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node -e \"const fs=require('node:fs'); fs.rmSync('./dist-test', { recursive: true, force: true }); fs.rmSync('./tsconfig.test.tsbuildinfo', { force: true });\" && tsc -p ./tsconfig.test.json && node --test \"./dist-test/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
