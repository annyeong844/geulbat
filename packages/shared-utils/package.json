{
  "name": "@geulbat/shared-utils",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    "./identifier-naming": {
      "types": "./dist/identifier-naming.d.ts",
      "import": "./dist/identifier-naming.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./process-command": {
      "types": "./dist/process-command.d.ts",
      "import": "./dist/process-command.js"
    },
    "./sha256": {
      "types": "./dist/sha256.d.ts",
      "import": "./dist/sha256.js"
    },
    "./stable-json": {
      "types": "./dist/stable-json.d.ts",
      "import": "./dist/stable-json.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test:files": "node ../../scripts/run-workspace-node-tests.mjs --workspace shared-utils --tsconfig ./tsconfig.test.json",
    "test": "npm run test:files -- \"**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
