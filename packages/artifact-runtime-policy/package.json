{
  "name": "@geulbat/artifact-runtime-policy",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    "./react-bundle-url": {
      "types": "./dist/react-bundle-url.d.ts",
      "import": "./dist/react-bundle-url.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
